---
import type { MobileMenuProps } from "./MobileMenu.interfaces";
import LangSwitch from "./LangSwitch.astro";
import ThemeToggle from "./ThemeToggle.astro";

type Props = MobileMenuProps;

const {
  locale,
  path,
  links,
  ctaLabel,
  ctaHref,
  openLabel,
  closeLabel,
  toggleThemeLabel,
} = Astro.props;
---

<button
  type="button"
  class="icon-btn menu-trigger"
  data-mobile-menu-trigger
  aria-label={openLabel}
  aria-expanded="false"
  aria-controls="mobile-menu-sheet"
  data-open-label={openLabel}
  data-close-label={closeLabel}
>
  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
    <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
  </svg>
</button>

<div
  id="mobile-menu-sheet"
  class="mobile-menu"
  data-mobile-menu
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
>
  <div class="top">
    <span class="brand">Markish.</span>
    <button type="button" class="icon-btn" data-mobile-menu-close aria-label={closeLabel}>
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
        <path d="M5 5l14 14M19 5L5 19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
      </svg>
    </button>
  </div>
  <nav>
    {links.map((link, index) => (
      <a href={link.href} data-mobile-menu-link>
        <span class="num">{String(index + 1).padStart(2, "0")}</span>
        {link.label}
      </a>
    ))}
  </nav>
  <div class="foot">
    <LangSwitch current={locale} path={path} />
    <ThemeToggle toggleLabel={toggleThemeLabel} />
    <a class="btn btn-primary" href={ctaHref} data-mobile-menu-link>
      {ctaLabel}
    </a>
  </div>
</div>
