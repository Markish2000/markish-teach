---
import { LOCALES } from "@shared/types";
import type { Locale } from "@shared/types";
import type { LangSwitchProps } from "./LangSwitch.interfaces";

type Props = LangSwitchProps;

const { current, path } = Astro.props;

const buildAlternateUrl = (currentPath: string, target: Locale): string => {
  const segments = currentPath.split("/").filter(Boolean);
  if (segments.length === 0) return `/${target}`;
  const first = segments[0] ?? "";
  if ((LOCALES as readonly string[]).includes(first)) {
    segments[0] = target;
  } else {
    segments.unshift(target);
  }
  return `/${segments.join("/")}`;
};
---

<div class="lang-switch" role="group" aria-label="Language">
  {LOCALES.map((locale) => (
    <a
      href={buildAlternateUrl(path, locale)}
      class:list={[locale === current && "is-active"]}
      aria-current={locale === current ? "true" : undefined}
      lang={locale}
    >
      {locale}
    </a>
  ))}
</div>
