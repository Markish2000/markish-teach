---
import type { Locale } from "@shared/types";
import { getTranslations } from "@i18n";
import Brand from "@shared/components/brand/Brand.astro";

interface Props {
  readonly locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale).foot;
---

<footer class="site-footer reveal-group" role="contentinfo">
  <div class="footer-brand">
    <Brand text="Markish." />
  </div>
  <div class="footer-row">
    <span class="meta">{t.copy}</span>
    <span class="meta">{t.meta}</span>
  </div>
</footer>
