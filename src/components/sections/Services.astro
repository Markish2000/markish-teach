---
import type { Locale } from "@shared/types";
import { getTranslations } from "@i18n";
import SectionHead from "@shared/components/sections/SectionHead.astro";
import IconShape from "@shared/components/primitives/IconShape.astro";

interface Props {
  readonly locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale).services;

const serviceIcons: ReadonlyArray<string> = [
  "M4 7h16M4 12h16M4 17h10",
  "M5 5h14v14H5z M5 12h14",
  "M3 12h4l3-7 4 14 3-7h4",
  "M12 3l9 4-9 14L3 7z",
  "M12 4a8 8 0 100 16 8 8 0 000-16zm0 4v4l3 2",
  "M4 7h6v6H4z M14 4h6v6h-6z M14 14h6v6h-6z M4 14h6v6H4z",
  "M5 19V5l7 7 7-7v14",
];
---

<section id="services" class="services" aria-labelledby="services-title">
  <div class="container-mk">
    <SectionHead id="services" eyebrow={t.eyebrow} title={t.title} meta={t.meta} />
    <div class="services-grid">
      {t.items.map((item, index) => (
        <article class:list={["service", { "is-feature": index === 0 }]}>
          <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
            <IconShape>
              <svg viewBox="0 0 24 24" fill="none">
                <path d={serviceIcons[index] ?? serviceIcons[0]} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </IconShape>
            <span class={index === 0 ? "pill-tag" : "num"}>{item.tag}</span>
          </div>
          <h3>{item.title}</h3>
          <p>{item.desc}</p>
          <div class="service-foot">
            <span>{item.foot}</span>
            <svg width="14" height="14" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
