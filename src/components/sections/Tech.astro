---
import type { Locale } from "@shared/types";
import { getTranslations } from "@i18n";
import SectionHead from "@shared/components/sections/SectionHead.astro";

interface Props {
  readonly locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale).tech;
const doubled: ReadonlyArray<string> = [...t.items, ...t.items];
---

<section id="tech" aria-labelledby="tech-title">
  <div class="container-mk">
    <SectionHead id="tech" eyebrow={t.eyebrow} title={t.title} />
  </div>
  <div class="tech-marquee" aria-hidden="true">
    <div class="tech-track">
      {doubled.map((item) => (
        <span class="tech-item">
          <span class="swatch" aria-hidden="true"></span>
          {item}
        </span>
      ))}
    </div>
  </div>
  <ul class="sr-only-list">
    {t.items.map((item) => <li>{item}</li>)}
  </ul>
</section>

<style>
  .sr-only-list {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
