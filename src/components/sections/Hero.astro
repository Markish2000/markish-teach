---
import type { Locale } from "@shared/types";
import { getTranslations } from "@i18n";
import Button from "@shared/components/primitives/Button.astro";
import Pill from "@shared/components/primitives/Pill.astro";

interface Props {
  readonly locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale).hero;
---

<section id="top" class="hero" aria-labelledby="hero-title">
  <div class="hero-coords" aria-hidden="true">
    <span>34°36'S · 58°22'W · BUENOS AIRES</span>
    <span>v1.0 · 2026</span>
  </div>
  <div class="container-mk">
    <div class="hero-grid">
      <div>
        <div class="hero-meta-row">
          <span class="eyebrow">{t.eyebrow}</span>
          <Pill text={t.status} pulse />
        </div>
        <h1 id="hero-title">
          <span class="word">{t.title_a}</span>{" "}
          <br class="hero-title-break" />
          <span class="word accent-word">{t.title_b}</span>
          <span class="word">{t.title_c}</span>
        </h1>
        <p class="lede" style="margin-top: 28px;">{t.subtitle}</p>
        <div class="hero-cta">
          <Button variant="primary" href="#contact" label={t.cta_primary} />
          <Button variant="secondary" href="#work" label={t.cta_secondary} />
        </div>
        <div class="hero-trust">
          <div class="stat">
            <div class="num">{t.stat1_num}<span class="unit">/100</span></div>
            <div class="label">{t.stat1_label}</div>
          </div>
          <div class="stat">
            <div class="num">{t.stat2_num}<span class="unit">s</span></div>
            <div class="label">{t.stat2_label}</div>
          </div>
          <div class="stat">
            <div class="num">{t.stat3_num}</div>
            <div class="label">{t.stat3_label}</div>
          </div>
        </div>
      </div>

      <div class="hero-stage">
        <div class="hero-3d-mount" data-hero-3d-mount>
          <div class="hero-3d-fallback" data-hero-3d-fallback aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
        <div class="hud-panel p1">
          <div class="label">SEO</div>
          <div class="value">100 <span class="ok">◉</span></div>
          <div class="bar"><i style="width: 100%;"></i></div>
        </div>
        <div class="hud-panel p2">
          <div class="label">Performance</div>
          <div class="value">100</div>
          <div class="bar"><i style="width: 100%;"></i></div>
        </div>
        <div class="hud-panel p3">
          <div class="label">Accessibility</div>
          <div class="value">AA <span class="ok">✓</span></div>
        </div>
        <div class="hud-panel p4">
          <div class="label">Responsive</div>
          <div class="value">320 → 4K</div>
        </div>
        <div class="hud-panel p5">
          <div class="label">Automation</div>
          <div class="value">24/7</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  type IdleWindow = Window & {
    requestIdleCallback?: (callback: IdleRequestCallback, options?: IdleRequestOptions) => number;
  };

  const mountHero3D = (() => {
    let loaded = false;

    return async (mount: HTMLElement): Promise<void> => {
      if (loaded) return;
      loaded = true;

      if (import.meta.env.DEV) {
        await import("@vitejs/plugin-react/preamble");
      }

      const [{ createElement }, { createRoot }, { default: Hero3D }] = await Promise.all([
        import("react"),
        import("react-dom/client"),
        import("@components/three/Hero3D"),
      ]);

      createRoot(mount).render(createElement(Hero3D));
    };
  })();

  const scheduleHero3D = (mount: HTMLElement): void => {
    let scheduled = false;
    const idleWindow = window as IdleWindow;

    const schedule = (): void => {
      if (scheduled) return;
      scheduled = true;
      window.setTimeout(() => {
        if (idleWindow.requestIdleCallback) {
          idleWindow.requestIdleCallback(() => void mountHero3D(mount), { timeout: 3200 });
          return;
        }
        window.setTimeout(() => void mountHero3D(mount), 1600);
      }, 1200);
    };

    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (!entry?.isIntersecting) return;
          observer.disconnect();
          schedule();
        },
        { threshold: 0.05 }
      );
      observer.observe(mount);
    } else {
      schedule();
    }

    window.addEventListener("pointerdown", () => void mountHero3D(mount), {
      once: true,
      passive: true,
    });
  };

  const hero3DMount = document.querySelector<HTMLElement>("[data-hero-3d-mount]");
  if (hero3DMount) scheduleHero3D(hero3DMount);
</script>
